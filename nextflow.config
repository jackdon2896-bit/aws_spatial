params {
    // Input data paths - choose one option for each type
    
    // OPTION 1: Use SRA accessions for scRNA-seq (e.g., GSE200972 samples)
    sra_accessions = null  // e.g., "SRR18196347,SRR18196348" (comma-separated list)
    
    // OPTION 2: Use pre-processed H5 file
    h5 = null  // e.g., "s3://your-bucket/path/to/data.h5"
    
    // SPATIAL DATA OPTIONS
    // OPTION 1: Download from 10x Genomics directly
    spatial_data_url = null  // e.g., "https://cf.10xgenomics.com/samples/spatial-exp/..."
    
    // OPTION 2: Use pre-existing TIFF image
    tiff = null  // e.g., "s3://your-bucket/path/to/image.tif"
    
    // Gene filtering (optional) - provide comma-separated gene IDs/names
    gene_ids = null  // e.g., "TP53,EGFR,KRAS,MYC"
    
    // Output directory (REQUIRED)
    outdir = "s3://tiffimage/results/"
    
    // AWS-specific settings
    aws_region = "ap-south-1"
}

docker {
    enabled = true
}

wave {
    enabled = true
}

process {
    executor = 'awsbatch'
    
    // Optimized Wave container with all dependencies
    container = 'community.wave.seqera.io/library/cellpose_celltypist_imageio_leidenalg_pruned:a05017b20bc0977c'
    
    // Default resources
    cpus = 2
    memory = '4 GB'
    time = '2h'
    
    // AWS HealthOmics compatibility settings
    errorStrategy = 'retry'
    maxRetries = 2
    
    // Process-specific resource configurations
    withName: SRA_DOWNLOAD {
        // SRA download uses different container
        cpus = 4
        memory = '8 GB'
        time = '6h'
    }
    
    withName: FASTQ_TO_COUNTS {
        cpus = 4
        memory = '16 GB'
        time = '8h'
    }
    
    withName: DOWNLOAD_SPATIAL_DATA {
        cpus = 2
        memory = '4 GB'
        time = '2h'
    }
    
    withName: PREPROCESS_IMAGE {
        cpus = 2
        memory = '8 GB'
    }
    
    withName: CELLPOSE_SEGMENT {
        cpus = 4
        memory = '16 GB'
        time = '4h'
    }
    
    withName: AI_ROI_CROP {
        cpus = 2
        memory = '8 GB'
    }
    
    withName: SCRNA_QC {
        cpus = 2
        memory = '8 GB'
    }
    
    withName: SCRNA_MAD_FILTER {
        cpus = 2
        memory = '8 GB'
    }
    
    withName: SCRNA_DIM_REDUCTION {
        cpus = 4
        memory = '16 GB'
    }
    
    withName: SCRNA_CLUSTER {
        cpus = 4
        memory = '16 GB'
    }
    
    withName: SCRNA_ANNOTATE {
        cpus = 4
        memory = '16 GB'
        time = '4h'
    }
    
    withName: SPATIAL_REFINE {
        cpus = 2
        memory = '8 GB'
    }
    
    withName: SPATIAL_INTEGRATION {
        cpus = 2
        memory = '8 GB'
    }
    
    withName: 'SCRNA_PLOTS|SPATIAL_PLOTS|REPORT' {
        cpus = 1
        memory = '4 GB'
    }
}

aws {
    region = params.aws_region
    batch {
        cliPath = '/home/ec2-user/miniconda/bin/aws'
        maxParallelTransfers = 16
        maxTransferAttempts = 3
    }
    client {
        maxConnections = 20
        connectionTimeout = 10000
        uploadMaxThreads = 16
        uploadChunkSize = '16MB'
        uploadStorageClass = 'INTELLIGENT_TIERING'
        storageEncryption = 'AES256'
    }
}

// AWS HealthOmics specific settings
manifest {
    name = 'aws-spatial-transcriptomics'
    author = 'Your Name'
    homePage = 'https://github.com/jackdon2896-bit/aws_spatial'
    description = 'Spatial transcriptomics pipeline integrating scRNA-seq and imaging data'
    mainScript = 'main.nf'
    version = '1.0.0'
    nextflowVersion = '>=23.04.0'
}

// Enable trace and timeline reports
trace {
    enabled = true
    file = "${params.outdir}/pipeline_trace.txt"
    overwrite = true
}

timeline {
    enabled = true
    file = "${params.outdir}/pipeline_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file = "${params.outdir}/pipeline_report.html"
    overwrite = true
}