// AWS Spatial Transcriptomics Pipeline Configuration
// Optimized for AWS HealthOmics with Wave containers

manifest {
    name = 'aws_spatial'
    author = 'jackdon2896-bit'
    description = 'Spatial Transcriptomics analysis pipeline for AWS HealthOmics'
    version = '1.0.0'
    mainScript = 'main.nf'
    nextflowVersion = '>=24.04.0'
}

// Pipeline parameters
params {
    // Input files (will be provided via S3)
    tiff = null                // Path to TIFF image file
    h5 = null                  // Path to H5 data file
    markers = null             // Path to marker genes file
    
    // Output directory
    outdir = 's3://your-bucket/results'
    
    // Cellpose parameters
    cellpose_model = 'cyto2'
    cellpose_diameter = 30
    cellpose_flow_threshold = 0.4
    cellpose_cellprob_threshold = 0.0
    
    // Clustering parameters
    cluster_resolution = 1.0
    n_neighbors = 15
    n_pcs = 50
    
    // Help message
    help = false
}

// AWS HealthOmics optimized process configuration
process {
    // Global Wave container for all processes
    // This container includes: cellpose, celltypist, imageio, leidenalg
    container = 'community.wave.seqera.io/library/cellpose_celltypist_imageio_leidenalg_pruned:a05017b20bc0977c'
    
    // Default resources
    cpus = 2
    memory = '8 GB'
    
    // Process-specific resources
    withName: CELLPOSE_SEGMENT {
        cpus = 4
        memory = '16 GB'
    }
    
    withName: SCRNA_CLUSTER {
        cpus = 4
        memory = '16 GB'
    }
    
    withName: SCRNA_ANNOTATE {
        cpus = 2
        memory = '8 GB'
    }
}

// AWS HealthOmics profile
profiles {
    awshealthomics {
        process {
            executor = 'aws-batch'
            container = 'community.wave.seqera.io/library/cellpose_celltypist_imageio_leidenalg_pruned:a05017b20bc0977c'
        }
        
        // AWS-specific settings
        aws {
            batch {
                cliPath = '/usr/local/bin/aws'
                maxTransferAttempts = 3
                delayBetweenAttempts = '30 sec'
            }
            region = 'us-east-1'  // Change to your region
        }
        
        // Enable Wave for container provisioning
        wave {
            enabled = true
        }
        
        // Enable Fusion for optimized S3 access
        fusion {
            enabled = true
        }
    }
    
    // Docker profile for local testing
    docker {
        docker.enabled = true
        process.container = 'community.wave.seqera.io/library/cellpose_celltypist_imageio_leidenalg_pruned:a05017b20bc0977c'
    }
    
    // Singularity profile for HPC
    singularity {
        singularity.enabled = true
        process.container = 'community.wave.seqera.io/library/cellpose_celltypist_imageio_leidenalg_pruned:a05017b20bc0977c'
    }
}

// Execution reports
timeline {
    enabled = true
    file = "${params.outdir}/timeline.html"
}

report {
    enabled = true
    file = "${params.outdir}/report.html"
}

trace {
    enabled = true
    file = "${params.outdir}/trace.txt"
}

dag {
    enabled = true
    file = "${params.outdir}/dag.html"
}
