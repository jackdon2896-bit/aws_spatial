/*
 * Configuration for processing very large spatial transcriptomics images (>5GB)
 * 
 * This config optimizes tile-based processing for images that would otherwise
 * cause memory crashes. Recommended for TIFF files >5GB.
 * 
 * Usage:
 *   nextflow run main.nf -c conf/large_image.config \
 *     --tiff s3://bucket/12gb_image.tif \
 *     --h5 s3://bucket/data.h5
 */

params {
    // Tile-based processing optimized for large images
    enable_tiling = true
    tile_size = 1024        // Smaller tiles for safer memory usage
    save_tiles = true       // Save tiles for debugging if needed
}

process {
    // Increase resources for tile processing
    withName: TILE_SPLIT {
        cpus = 4
        memory = '32 GB'
        time = '2h'
    }
    
    withName: PREPROCESS {
        cpus = 4
        memory = '16 GB'
        time = '3h'
    }
    
    withName: SEGMENT {
        cpus = 8
        memory = '32 GB'
        time = '6h'
        // Uncomment if GPU available for 5-10x speedup
        // accelerator = 1
        // containerOptions = '--gpus all'
    }
    
    withName: ROI_CROP {
        cpus = 4
        memory = '16 GB'
        time = '3h'
    }
    
    withName: MERGE_TILES {
        cpus = 4
        memory = '32 GB'
        time = '3h'
    }
}

// Allow more parallel tile processing
executor {
    queueSize = 50  // Process up to 50 tiles in parallel
}
