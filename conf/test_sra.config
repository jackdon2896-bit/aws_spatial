// Test configuration for SRA download functionality

params {
    // Test with SRA data
    tiff = "s3://tiffimage/tiffimage/lungstiff.tif"
    sra_ids = "SRR123456,SRR123457"  // Replace with actual SRA IDs
    
    // Output directory
    outdir = "s3://tiffimage/results/test_sra/"
}

// Reduced resources for testing
process {
    withName: SRA_DOWNLOAD {
        cpus = 2
        memory = '4 GB'
        time = '3h'
    }
    
    withName: FASTQ_TO_H5AD {
        cpus = 1
        memory = '4 GB'
        time = '1h'
    }
}