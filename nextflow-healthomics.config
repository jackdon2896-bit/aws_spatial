// AWS HealthOmics Optimized Configuration
// This configuration is specifically designed for AWS HealthOmics execution

params {
    // Input data paths - will be overridden by HealthOmics run parameters
    tiff = null
    h5   = null
    sra_ids = null
    outdir = null
    
    // HealthOmics specific parameters
    max_memory = '64.GB'
    max_cpus = 16
    max_time = '24.h'
}

// HealthOmics process configuration
process {
    // Use ECR container instead of Wave for HealthOmics
    container = 'ACCOUNT_ID.dkr.ecr.REGION.amazonaws.com/aws-spatial-pipeline:latest'
    
    // HealthOmics executor settings
    executor = 'awsbatch'
    queue = 'default'
    
    // Error handling for HealthOmics
    errorStrategy = 'retry'
    maxRetries = 3
    
    // Resource limits for HealthOmics
    cpus = { check_max(2, 'cpus') }
    memory = { check_max(4.GB * task.attempt, 'memory') }
    time = { check_max(2.h * task.attempt, 'time') }
    
    // Process-specific configurations optimized for HealthOmics
    withName: PREPROCESS_IMAGE {
        cpus = { check_max(2, 'cpus') }
        memory = { check_max(8.GB * task.attempt, 'memory') }
        time = { check_max(1.h * task.attempt, 'time') }
    }
    
    withName: CELLPOSE_SEGMENT {
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(4.h * task.attempt, 'time') }
        accelerator = 1
    }
    
    withName: AI_ROI_CROP {
        cpus = { check_max(2, 'cpus') }
        memory = { check_max(8.GB * task.attempt, 'memory') }
        time = { check_max(1.h * task.attempt, 'time') }
    }
    
    withName: 'SCRNA_QC|SCRNA_MAD_FILTER' {
        cpus = { check_max(2, 'cpus') }
        memory = { check_max(8.GB * task.attempt, 'memory') }
        time = { check_max(1.h * task.attempt, 'time') }
    }
    
    withName: 'SCRNA_DIM_REDUCTION|SCRNA_CLUSTER' {
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(2.h * task.attempt, 'time') }
    }
    
    withName: SCRNA_ANNOTATE {
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(3.h * task.attempt, 'time') }
    }
    
    withName: 'SPATIAL_REFINE|SPATIAL_INTEGRATION' {
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(2.h * task.attempt, 'time') }
    }
    
    withName: SRA_DOWNLOAD {
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(8.GB * task.attempt, 'memory') }
        time = { check_max(6.h * task.attempt, 'time') }
    }
    
    withName: FASTQ_TO_H5AD {
        cpus = { check_max(4, 'cpus') }
        memory = { check_max(16.GB * task.attempt, 'memory') }
        time = { check_max(2.h * task.attempt, 'time') }
    }
    
    withName: 'SCRNA_PLOTS|SPATIAL_PLOTS|REPORT' {
        cpus = { check_max(2, 'cpus') }
        memory = { check_max(4.GB * task.attempt, 'memory') }
        time = { check_max(1.h * task.attempt, 'time') }
    }
}

// AWS HealthOmics specific settings
aws {
    region = 'us-east-1'  // Will be set by HealthOmics
    client {
        maxConnections = 20
        connectionTimeout = 300000
        uploadStorageClass = 'STANDARD_IA'
        storageEncryption = 'AES256'
        maxErrorRetry = 3
    }
}

// HealthOmics environment variables
env {
    AWS_DEFAULT_REGION = 'us-east-1'
    AWS_MAX_ATTEMPTS = '3'
    AWS_RETRY_MODE = 'adaptive'
    PYTHONUNBUFFERED = '1'
}

// Resource checking function for HealthOmics limits
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max memory '${params.max_memory}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else
                return obj
        } catch (all) {
            println "   ### ERROR ###   Max time '${params.max_time}' is not valid! Using default value: $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min( obj, params.max_cpus as int )
        } catch (all) {
            println "   ### ERROR ###   Max cpus '${params.max_cpus}' is not valid! Using default value: $obj"
            return obj
        }
    }
}

// Manifest for HealthOmics
manifest {
    name = 'aws-spatial-transcriptomics'
    author = 'AWS HealthOmics Pipeline'
    homePage = 'https://github.com/jackdon2896-bit/aws_spatial'
    description = 'Spatial transcriptomics analysis pipeline with SRA download capability'
    mainScript = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version = '1.0.0'
}