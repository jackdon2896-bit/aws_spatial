// Example configuration using pre-computed H5 and TIFF files
params {
    // Use pre-processed H5 file (already in S3)
    h5 = "s3://tiffimage/tiffimage/lungsfeaturematrix.h5"
    
    // Use pre-existing TIFF image (already in S3)
    tiff = "s3://tiffimage/tiffimage/lungstiff.tif"
    
    // Optional: Filter for specific genes
    gene_ids = "TP53,EGFR,KRAS"
    
    // Output to S3
    outdir = "s3://tiffimage/results/precomputed_run"
    
    // AWS region
    aws_region = "ap-south-1"
}
