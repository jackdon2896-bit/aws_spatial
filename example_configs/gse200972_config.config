// Example configuration for GSE200972 (Lung Cancer scRNA-seq) + 10x Visium HD spatial data
params {
    // Use SRA accessions from GSE200972
    // Note: Replace with actual SRA accessions from the GEO dataset
    sra_accessions = "SRR18196347,SRR18196348,SRR18196349"
    
    // Download 10x Visium HD spatial data
    spatial_data_url = "https://cf.10xgenomics.com/samples/spatial-exp/3.0.0/Visium_HD_Human_Lung_Cancer/Visium_HD_Human_Lung_Cancer_tissue_image.tif"
    
    // Optional: Filter for specific genes of interest
    gene_ids = "TP53,EGFR,KRAS,MYC,ALK,ROS1,BRAF,MET,RET,ERBB2"
    
    // Output to S3
    outdir = "s3://tiffimage/results/gse200972_run"
    
    // AWS region
    aws_region = "ap-south-1"
}
